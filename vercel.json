{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/auth/login",   "destination": "/api/auth/login.js" },
    { "source": "/api/auth/me",      "destination": "/api/auth/me.js" },
    { "source": "/api/chat/save",    "destination": "/api/chat/save.js" },
    { "source": "/api/chat/history", "destination": "/api/chat/history.js" },
    { "source": "/api/chat/delete",  "destination": "/api/chat/delete.js" },
    { "source": "/api/admin",        "destination": "/api/admin.js" },
    { "source": "/api/ai",           "destination": "/api/ai.js" },
    { "source": "/admin",            "destination": "/admin.html" },
    { "source": "/login",            "destination": "/login.html" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
